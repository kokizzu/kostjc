{
	"name": "kostjc",
	"version": "0.0.0",
	"scripts": {
		"start": "npm run dev",
		"watch": "npm run build -- --watch",
		"dev": "node build.mjs --watch --serve",
		"build": "node build.mjs",
		"build:prod": "node build.mjs --minify",
		"serve": "node build.mjs --serve"
	},
	"dependencies": {
		"@googlemaps/js-api-loader": "^1.16.10",
		"axios": "^1.18.0",
		"chart.js": "^4.5.1",
		"file-selector": "^0.2.4",
		"lodash-es": "^4.18.1",
		"svelte-highlight": "^7.11.0",
		"svelte-icons-pack": "^3.1.3",
		"svelte-select": "^5.8.3"
	},
	"devDependencies": {
		"@types/google.maps": "^3.65.2",
		"chokidar": "^3.6.0",
		"esbuild": "^0.27.7",
		"esbuild-svelte": "^0.9.5",
		"five-server": "^0.4.5",
		"node-notifier": "^10.0.1",
		"parse5": "^7.3.0",
		"prettier": "^2.8.8",
		"svelte": "^5.56.3",
		"svelte-preprocess": "^5.1.4",
		"typescript": "^5.9.3"
	},
	"prettier": {
		"singleQuote": true,
		"trailingComma": "es5",
		"printWidth": 120,
		"arrowParens": "avoid"
	},
	"pnpm": {
		"ignoredBuiltDependencies": [
			"esbuild",
			"svelte-preprocess"
		],
		"onlyBuiltDependencies": [
			"esbuild",
			"svelte-preprocess"
		]
	}
